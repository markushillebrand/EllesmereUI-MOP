# Libraries
# NOTE: The GitHub source archive does not include git submodules. Copy the
#       Libs/ folder from your original EllesmereUI working copy into this
#       addon folder. LibKeystone is intentionally omitted (Mythic+ only).
Libs\LibStub\LibStub.lua
Libs\CallbackHandler-1.0\CallbackHandler-1.0.lua
Libs\LibSharedMedia-3.0\LibSharedMedia-3.0.lua
Libs\LibDeflate\LibDeflate.lua

# Lightweight addon framework (replaces Ace3)
EllesmereUI_Lite.lua

# MoP Classic compatibility shim layer (must load right after Lite, before all
# other files, so the API fallbacks exist before any module code runs).
EUI_Compat.lua

# Central multi-language engine (resolves locale + glyph font; defines L/Lf/EnKey)
EllesmereUI_Locale.lua

# Community translation files (one per locale; only the active one builds entries).
Locales\deDE.lua
Locales\esES.lua
Locales\esMX.lua
Locales\frFR.lua
Locales\itIT.lua
Locales\koKR.lua
Locales\ptBR.lua
Locales\ruRU.lua
Locales\zhCN.lua
Locales\zhTW.lua

# Translation harvester (/euiloc dev tool; inert until invoked)
EllesmereUI_LocaleDev.lua

# One-time data migration (runs before child addons init)
EllesmereUI_Migration.lua

# Early startup -- applies engine-cached settings before PLAYER_LOGIN
EllesmereUI_Startup.lua

